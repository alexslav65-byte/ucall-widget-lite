<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:layout_width="match_parent"
    tools:layout_height="@dimen/widget_container_height"
    tools:background="#000000">

    <!-- Крапочки -->
    <LinearLayout
        android:id="@+id/swipe_zone"
        android:layout_width="21dp"
        android:layout_height="match_parent"
        android:layout_alignParentStart="true"
        android:layout_marginEnd="@dimen/widget_spacing"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginTop="@dimen/widget_spacing"
            android:src="@drawable/dot_shape" />

        <ImageView
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginTop="@dimen/widget_spacing"
            android:src="@drawable/dot_shape" />

        <ImageView
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginTop="@dimen/widget_spacing"
            android:layout_marginBottom="@dimen/widget_spacing"
            android:src="@drawable/dot_shape" />
    </LinearLayout>

    <!-- Контейнер тексту -->
    <FrameLayout
        android:id="@+id/text_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_toEndOf="@id/swipe_zone"
        android:layout_toStartOf="@id/call_button_container"
        android:layout_marginStart="@dimen/widget_spacing"
        android:layout_marginEnd="0dp"
        android:background="@drawable/bg_text_container">

        <TextClock
            android:id="@+id/background_clock"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="8dp"
            android:fontFamily="sans-serif-light"
            android:format12Hour="h:mm"
            android:format24Hour="HH:mm"
            android:gravity="center"
            android:includeFontPadding="false"
            android:singleLine="true"
            android:textColor="@color/widget_clock_background_text"
            android:textSize="@dimen/widget_background_clock_text_size"
            android:textStyle="bold"
            tools:text="12:30" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="vertical">

        <!-- Ім’я -->
        <TextView
            android:id="@+id/name_button"
            android:layout_width="match_parent"
            android:layout_height="@dimen/lc_name_row_height"
            android:paddingStart="0dp"
            android:paddingEnd="12dp"
            android:text="Ім’я"
            android:textColor="#FFFFFF"
            android:textSize="@dimen/lc_name_text_size"
            android:textStyle="bold"
            android:gravity="start|bottom"
            android:ellipsize="end"
            android:singleLine="true"
            android:shadowColor="#CC000000"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="4"
            tools:text="Ім’я контакту" />

        <!-- Блок номеру + часу (СТАЛИЙ по висоті, елементи незалежні) -->
        <RelativeLayout
            android:id="@+id/number_time_container"
            android:layout_width="match_parent"
            android:layout_height="@dimen/lc_number_row_height"
            android:paddingEnd="4dp">

            <!-- Час (якір: низ + правий край) -->
            <LinearLayout
                android:id="@+id/call_time_container"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_alignParentEnd="true"
                android:layout_alignParentBottom="true"
                android:layout_marginBottom="3dp"
                android:orientation="vertical"
                android:gravity="bottom|center_horizontal">

                <TextView
                    android:id="@+id/call_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="12:34"
                    android:textSize="@dimen/lc_time_text_size"
                    android:textColor="#000000"
                    android:background="@drawable/bg_call_time_pill"
                    android:shadowColor="#CC000000"
                    android:shadowDx="0"
                    android:shadowDy="0"
                    android:shadowRadius="2"
                    android:gravity="center"
                    android:singleLine="true"
                    android:ellipsize="end"
                    android:paddingLeft="6dp"
                    android:paddingRight="6dp"
                    tools:text="12:34" />
            </LinearLayout>

            <!-- Номер (якір: верх, і не заходить під час) -->
            <TextView
                android:id="@+id/number_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_alignParentTop="true"
                android:layout_toStartOf="@id/call_time_container"
                android:paddingStart="0dp"
                android:paddingEnd="6dp"
                android:text="Номер"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="@dimen/lc_number_text_size"
                android:fontFamily="sans-serif"
                android:ellipsize="end"
                android:singleLine="true"
                android:gravity="start|top"
                android:shadowColor="#CC000000"
                android:shadowDx="0"
                android:shadowDy="0"
                android:shadowRadius="4"
                tools:text="+380 67 123 45 67" />

        </RelativeLayout>

        </LinearLayout>

    </FrameLayout>

    <!-- Кнопка виклику -->
    <LinearLayout
        android:id="@+id/call_button_container"
        android:layout_width="40dp"
        android:layout_height="match_parent"
        android:layout_alignParentEnd="true"
        android:background="@drawable/bg_call_button"
        android:gravity="center">

        <ImageButton
            android:id="@+id/call_button"
            android:layout_width="32dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:adjustViewBounds="true"
            android:background="@android:color/transparent"
            android:scaleType="centerInside"
            android:src="@drawable/call_slash" />
    </LinearLayout>

    <!-- ===================================================== -->
    <!-- ГЛОБАЛЬНИЙ ПРОЗОРИЙ ХІТБОКС ДЛЯ НАЛАШТУВАНЬ (НОВЕ)     -->
    <!-- Притиснутий до низу/правого краю, не перекриває Call  -->
    <!-- Має бути ОСТАННІМ, щоб бути поверх text_container      -->
    <!-- ===================================================== -->
    <FrameLayout
        android:id="@+id/settings_hitbox_global"
        android:layout_width="50dp"
        android:layout_height="30dp"
        android:layout_alignParentBottom="true"
        android:layout_toStartOf="@id/call_button_container"
        android:background="@android:color/transparent"
        android:padding="1dp" />


</RelativeLayout>
