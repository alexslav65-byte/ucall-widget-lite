<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:fillViewport="true"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_widget_help"
                android:layout_width="166dp"
                android:layout_height="36dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:paddingHorizontal="12dp"
                android:text="@string/widget_help_button"
                android:textAllCaps="false"
                android:textColor="#000000"
                android:textSize="12sp"
                app:backgroundTint="@android:color/white"
                app:cornerRadius="18dp"
                app:rippleColor="#22000000" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <RadioGroup
                android:id="@+id/lang_group"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/lang_ua"
                    android:layout_width="64dp"
                    android:layout_height="36dp"
                    android:background="@drawable/lang_ua_bg_selector"
                    android:buttonTint="@android:color/white"
                    android:text="UA"
                    android:textColor="@android:color/black"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:padding="0dp"
                    android:checked="true" />

                <RadioButton
                    android:id="@+id/lang_en"
                    android:layout_width="64dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/lang_en_bg_selector"
                    android:buttonTint="@android:color/white"
                    android:text="EN"
                    android:textColor="@android:color/black"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:padding="0dp" />
            </RadioGroup>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#33FFFFFF"
            android:layout_marginVertical="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/widget_settings_preview_title"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="@android:color/white"
            android:layout_marginBottom="4dp" />

        <FrameLayout
            android:id="@+id/widget_preview_host"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/preview_background"
            android:padding="4dp"
            android:layout_marginBottom="4dp">

            <include layout="@layout/widget_preview" />
        </FrameLayout>

        <Button
            android:id="@+id/btn_add_widget"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/add_widget_to_home"
            android:padding="12dp"
            android:layout_marginTop="8dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#33FFFFFF"
            android:layout_marginVertical="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/widget_settings_modes_block_title"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="@android:color/white" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/widget_spy_mode"
                android:textColor="@android:color/white"
                android:textSize="16sp" />

            <Switch
                android:id="@+id/switch_spy_mode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#33FFFFFF"
            android:layout_marginVertical="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/widget_settings_choose_theme"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="@android:color/white" />

        <RadioGroup
            android:id="@+id/theme_radio_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp">

            <RadioButton
                android:id="@+id/radio_dark"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/widget_theme_dark"
                android:textColor="@android:color/white"
                android:padding="2dp" />

            <RadioButton
                android:id="@+id/radio_light"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/widget_theme_light"
                android:textColor="@android:color/white"
                android:padding="2dp" />

            <RadioButton
                android:id="@+id/radio_standard"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/widget_theme_standard"
                android:textColor="@android:color/white"
                android:padding="2dp" />
        </RadioGroup>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#33FFFFFF"
            android:layout_marginVertical="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/widget_settings_font_size_title"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="@android:color/white" />

        <RadioGroup
            android:id="@+id/font_size_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/radio_font_small"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/widget_font_small"
                android:textColor="@android:color/white"
                android:padding="2dp" />

            <RadioButton
                android:id="@+id/radio_font_medium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/widget_font_medium"
                android:textColor="@android:color/white"
                android:padding="2dp" />

            <RadioButton
                android:id="@+id/radio_font_large"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/widget_font_large"
                android:textColor="@android:color/white"
                android:padding="2dp" />
        </RadioGroup>

        <Button
            android:id="@+id/btn_done"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_done"
            android:textAllCaps="false"
            android:layout_marginTop="16dp" />

        <TextView
            android:id="@+id/txt_refresh_diagnostics"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="#99FFFFFF"
            android:textSize="11sp"
            android:fontFamily="monospace" />
    </LinearLayout>
</ScrollView>
