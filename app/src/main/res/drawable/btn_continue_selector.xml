<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Активний стан -->
    <item android:state_enabled="true">
        <shape android:shape="rectangle">
            <solid android:color="#1976D2" /> <!-- синій -->
            <corners android:radius="8dp" />
            <padding
                android:left="12dp"
                android:top="10dp"
                android:right="12dp"
                android:bottom="10dp" />
        </shape>
    </item>

    <!-- Неактивний стан -->
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <solid android:color="#BDBDBD" /> <!-- сіро-блідий -->
            <corners android:radius="8dp" />
            <padding
                android:left="12dp"
                android:top="10dp"
                android:right="12dp"
                android:bottom="10dp" />
        </shape>
    </item>

</selector>
