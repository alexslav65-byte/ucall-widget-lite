<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Градієнт від прозорого до напівпрозорого і знову до прозорого -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="0"
                android:startColor="#00000000"
                android:centerColor="#66000000"
                android:endColor="#00000000"
                android:useLevel="false" />
        </shape>
    </item>

    <!-- Основний прямокутник всередині -->
    <item android:left="4dp" android:right="4dp" android:top="4dp" android:bottom="4dp">
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <solid android:color="#CC000000" />
            <stroke android:width="1dp" android:color="#66000000" />
        </shape>
    </item>

</layer-list>
