<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Основний фон -->
    <item>
        <shape>
            <gradient
                android:type="linear"
                android:angle="0"
                android:startColor="#00FFFFFF"
                android:centerColor="#22FFFFFF"
                android:endColor="#88FFFFFF"
                android:centerX="0.33" />
        </shape>
    </item>

    <!-- Верхня тонка смужка -->
    <item android:height="1dp" android:gravity="top">
        <shape>
            <gradient
                android:angle="0"
                android:startColor="#00FFFFFF"
                android:centerColor="#88FFFFFF"
                android:endColor="#00FFFFFF" />
        </shape>
    </item>

    <!-- Нижня тонка смужка -->
    <item android:height="1dp" android:gravity="bottom">
        <shape>
            <gradient
                android:angle="0"
                android:startColor="#00FFFFFF"
                android:centerColor="#88FFFFFF"
                android:endColor="#00FFFFFF" />
        </shape>
    </item>
</layer-list>
