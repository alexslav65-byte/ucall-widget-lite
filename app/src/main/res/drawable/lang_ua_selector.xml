<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Selected -->
    <item android:state_checked="true">
        <layer-list>
            <item android:drawable="@drawable/bg_lang_ua" />
            <item>
                <shape>
                    <stroke
                        android:width="2dp"
                        android:color="#FFFFFFFF" />
                    <corners android:radius="10dp" />
                </shape>
            </item>
        </layer-list>
    </item>

    <!-- Default -->
    <item>
        <layer-list>
            <item android:drawable="@drawable/bg_lang_ua" />
            <item>
                <shape>
                    <solid android:color="#66000000" />
                    <corners android:radius="10dp" />
                </shape>
            </item>
        </layer-list>
    </item>

</selector>
