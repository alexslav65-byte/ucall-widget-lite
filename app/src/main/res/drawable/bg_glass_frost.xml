<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Base glass -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#22FFFFFF"/>
            <corners android:radius="16dp"/>
        </shape>
    </item>

    <!-- Cold tint -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#334FC3F7"/>
            <corners android:radius="16dp"/>
        </shape>
    </item>

    <!-- Border -->
    <item>
        <shape android:shape="rectangle">
            <stroke
                android:width="1dp"
                android:color="#55FFFFFF"/>
            <corners android:radius="16dp"/>
        </shape>
    </item>

</layer-list>
