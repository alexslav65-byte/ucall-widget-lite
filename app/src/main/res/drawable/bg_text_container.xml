<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Основний фон -->
    <item>
        <shape>
            <gradient
                android:type="linear"
                android:angle="0"
                android:startColor="#00000000"
                android:centerColor="#22000000"
                android:endColor="#88000000"
                android:centerX="0.33" />
        </shape>
    </item>

    <!-- Верхня тонка смужка -->
    <item android:height="1dp" android:gravity="top">
        <shape>
            <gradient
                android:angle="0"
                android:startColor="#00000000"
                android:centerColor="#88000000"
                android:endColor="#00000000" />
        </shape>
    </item>

    <!-- Нижня тонка смужка -->
    <item android:height="1dp" android:gravity="bottom">
        <shape>
            <gradient
                android:angle="0"
                android:startColor="#00000000"
                android:centerColor="#88000000"
                android:endColor="#00000000" />
        </shape>
    </item>
</layer-list>
