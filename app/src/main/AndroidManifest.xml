<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">



    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <uses-permission android:name="android.permission.READ_CALL_LOG" />
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-permission android:name="android.permission.CALL_PHONE" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <uses-feature
        android:name="android.hardware.telephony"
        android:required="false" />

    <application
        android:name=".UCallLiteApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name_sorted"
        android:roundIcon="@mipmap/ic_launcher"
        android:theme="@style/AppTheme">

        <activity
            android:name=".AddWidgetStepActivity"
            android:exported="false"
            android:theme="@style/Theme.UCallLite.DialogActivity" />

        <activity
            android:name=".WidgetExplanationActivity"
            android:theme="@style/Theme.UCallWidget.NoActionBar" />

        <activity
            android:name=".PermissionGateActivity"
            android:exported="false"
            android:theme="@style/AppTheme.Transparent" />

        <activity
            android:name=".PermissionsOnboardingActivity"
            android:exported="false"
            android:theme="@style/AppTheme.Transparent" />

        <activity
            android:name=".WidgetActionActivity"
            android:exported="false"
            android:theme="@style/AppTheme.Transparent" />

        <activity
            android:name=".EndCallWakeActivity"
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:exported="false"
            android:theme="@style/Theme.UCall.Transparent" />

        <activity
            android:name=".SettingsEntryActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".OnboardingActivity"
            android:exported="false"
            android:theme="@style/Theme.UCallWidget.NoActionBar" />

        <activity
            android:name=".WidgetSettingsActivity"
            android:exported="false" />

        <receiver
            android:name=".WidgetActionReceiver"
            android:exported="false" />

        <receiver
            android:name=".WidgetBlinkReceiver"
            android:exported="false" />

        <receiver
            android:name=".CallEndReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.PHONE_STATE" />
            </intent-filter>
        </receiver>

        <receiver
            android:name=".MyWidgetProvider"
            android:exported="true"
            android:label="@string/widget_name_sorted">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_last_call_info" />
        </receiver>

        <receiver
            android:name=".MyWideWidgetProvider"
            android:exported="true"
            android:label="@string/widget_name_wide_sorted">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_last_call_info_wide" />
        </receiver>

    </application>
</manifest>
